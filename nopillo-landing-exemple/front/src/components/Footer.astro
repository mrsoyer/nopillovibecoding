---
const year = new Date().getFullYear()
---

<footer class="footer-nopillo">
  <div class="container-regular footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <img src="/logo-nopillo.svg" alt="Nopillo" width="140" height="32" class="footer-logo" />
        <p class="footer-tagline">
          Votre déclaration LMNP. Simplifiée. Optimisée.
        </p>
        <p class="footer-cred">
          Expert-comptable inscrit à l'Ordre des Experts-Comptables.
        </p>
      </div>

      <div class="footer-cols">
        <div class="footer-col">
          <h4>Produits</h4>
          <ul>
            <li><a href="#problem">Liasse fiscale 2031</a></li>
            <li><a href="#simulator">Simulateur LMNP</a></li>
            <li><a href="#problem">Régime réel</a></li>
            <li><a href="#problem">Optimisation fiscale</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Ressources</h4>
          <ul>
            <li><a href="#glossaire">Glossaire LMNP</a></li>
            <li><a href="#faq">FAQ</a></li>
            <li><a href="#testimonials">Témoignages</a></li>
            <li><a href="#contact">Nous contacter</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Légal</h4>
          <ul>
            <li><a href="/privacy">Confidentialité</a></li>
            <li><a href="/cgv">CGV</a></li>
            <li><a href="/mentions">Mentions légales</a></li>
            <li><a href="/cookies">Cookies</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Nopillo. Tous droits réservés.</p>
      <p class="footer-small">
        Cette landing est un exemple démo. Les chiffres affichés sont illustratifs.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-nopillo {
    padding: 80px 0 40px;
    background-color: var(--color-graycool-25, #FCFCFD);
    border-top: 1px solid var(--color-indigo-100, #DEDAFF);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--color-graycool-200, #DCDFEA);
  }

  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 1.5fr 2fr;
      gap: 64px;
    }
  }

  .footer-logo {
    height: 32px;
    margin-bottom: 16px;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--color-brand-black);
    margin-bottom: 8px;
  }

  .footer-cred {
    font-size: 14px;
    color: var(--color-graycool-500, #5D6B98);
    max-width: 300px;
    line-height: 1.5;
  }

  .footer-cols {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 24px;
  }

  @media (max-width: 600px) {
    .footer-cols {
      grid-template-columns: 1fr 1fr;
      gap: 32px 16px;
    }
  }

  .footer-col h4 {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-brand-black);
    margin-bottom: 16px;
  }

  .footer-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    font-size: 14px;
    color: var(--color-graycool-700, #404968);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-col a:hover {
    color: var(--color-indigo-600, #4033DB);
  }

  .footer-bottom {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 16px;
    font-size: 13px;
    color: var(--color-graycool-500, #5D6B98);
  }

  .footer-small {
    font-style: italic;
  }
</style>
