---
import DKIHero from '../DKIHero.tsx'
---
<section class="hero-nopillo">
  <div class="container-regular hero-inner">
    <div class="hero-grid">
      <!-- Colonne gauche : texte -->
      <div class="hero-content">
        <span class="badge-eyebrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z" fill="currentColor"/>
          </svg>
          Expert-comptable LMNP en ligne
        </span>

        <DKIHero client:load />

        <!-- CTAs : primary NOIR + ghost -->
        <div class="hero-cta">
          <a href="#contact" class="btn btn-primary btn-lg" data-cta-id="hero-primary" data-cta-position="hero">
            Calculer mes économies
          </a>
          <a href="#simulator" class="btn btn-ghost btn-lg" data-cta-id="hero-secondary" data-cta-position="hero">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="5 3 19 12 5 21 5 3" fill="currentColor"/>
            </svg>
            Parler à un conseiller
          </a>
        </div>

        <!-- Bandeau réassurance compact -->
        <div class="hero-trust">
          <div class="hero-trust-stars" aria-label="4.7 sur 5">
            {Array.from({length: 5}).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#FFB800"><path d="M12 .587l3.668 7.568L24 9.748l-6 5.847 1.416 8.252L12 19.771l-7.416 4.076L6 15.595 0 9.748l8.332-1.593z"/></svg>
            ))}
          </div>
          <span class="hero-trust-text">
            <strong>4,7/5</strong> sur 1 234 avis Trustpilot vérifiés
          </span>
        </div>
      </div>

      <!-- Colonne droite : mini-quiz interactif a la Nopillo -->
      <aside class="hero-quiz" aria-label="Quiz revenus locatifs">
        <p class="hero-quiz-title">
          Quel est le projet ou réalité de vos impôts ?
        </p>
        <div class="hero-quiz-options">
          <button class="hero-quiz-option" data-quiz="0-60">
            <span class="hero-quiz-dot" style="background-color: #DEDAFF;"></span>
            Moins de 60 K€
          </button>
          <button class="hero-quiz-option" data-quiz="60-80">
            <span class="hero-quiz-dot" style="background-color: #BDB5FF;"></span>
            Entre 60 K€ et 80 K€
          </button>
          <button class="hero-quiz-option" data-quiz="80-100">
            <span class="hero-quiz-dot" style="background-color: #9C90FF;"></span>
            Entre 80 K€ et 100 K€
          </button>
          <button class="hero-quiz-option" data-quiz="100+">
            <span class="hero-quiz-dot" style="background-color: #4033DB;"></span>
            Plus de 100 K€
          </button>
        </div>
        <p class="hero-quiz-help">
          Réponse anonyme — vous restez sur la page
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero-nopillo {
    /* Background indigo soft authentique Nopillo */
    background-color: rgba(222, 218, 255, 0.6);
    padding: 80px 0 96px;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .hero-nopillo {
      padding: 120px 0 100px;
    }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 64px;
    }
  }

  .hero-content .badge-eyebrow {
    margin-bottom: 24px;
  }

  /* CTAs */
  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
    margin-bottom: 24px;
  }

  /* Trust strip */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: var(--color-graycool-700, #404968);
  }

  .hero-trust-stars {
    display: flex;
    gap: 2px;
  }

  .hero-trust-text strong {
    color: var(--color-brand-black);
    font-weight: 600;
  }

  /* QUIZ (a la Nopillo) */
  .hero-quiz {
    background-color: var(--color-brand-white);
    border: 1px solid var(--color-indigo-100, #DEDAFF);
    border-radius: 16px;
    padding: 32px 28px;
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.06);
  }

  .hero-quiz-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--color-brand-black);
    margin-bottom: 20px;
    line-height: 1.3;
  }

  .hero-quiz-options {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 16px;
  }

  .hero-quiz-option {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background-color: rgba(222, 218, 255, 0.25);
    border: 1px solid var(--color-indigo-100, #DEDAFF);
    border-radius: 12px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-brand-black);
    text-align: left;
    cursor: pointer;
    transition: all 0.15s ease;
    width: 100%;
  }

  .hero-quiz-option:hover {
    background-color: rgba(222, 218, 255, 0.55);
    border-color: var(--color-indigo-300, #9C90FF);
    transform: translateX(2px);
  }

  .hero-quiz-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-quiz-help {
    font-size: 12px;
    color: var(--color-graycool-500, #5D6B98);
    text-align: center;
    margin: 0;
  }
</style>

<script>
  // Light tracking pour le quiz (purement client, non-bloquant)
  document.querySelectorAll('.hero-quiz-option').forEach((btn) => {
    btn.addEventListener('click', () => {
      const value = btn.getAttribute('data-quiz')
      window.dataLayer = window.dataLayer || []
      window.dataLayer.push({ event: 'hero_quiz_click', quiz_revenue: value })
      // Scroll smooth vers le formulaire
      document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' })
    })
  })
</script>
