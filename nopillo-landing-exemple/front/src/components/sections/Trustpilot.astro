---
const reviews = [
  { author: 'Sophie L.', stars: 5, date: 'il y a 3 jours', text: 'Service impeccable. Mon expert a tout pris en charge et m\'a fait économiser 4 200 € la 1re année.' },
  { author: 'Marc D.',   stars: 5, date: 'il y a 1 semaine', text: 'Rapidité et professionnalisme. Liasse 2031 envoyée en 5 jours, sans accroc.' },
  { author: 'Léa B.',    stars: 5, date: 'il y a 2 semaines', text: 'Enfin un expert-comptable LMNP transparent sur les tarifs. Je recommande vivement.' },
]
---
<section class="section trustpilot-section">
  <div class="container-regular">
    <div class="trustpilot-grid">
      <div class="trustpilot-summary">
        <p class="trustpilot-eyebrow">Note Trustpilot</p>
        <h2 class="trustpilot-title">
          <span class="trustpilot-score">4,7</span><span class="trustpilot-over">/5</span>
        </h2>
        <div class="trustpilot-stars" aria-label="4.7 sur 5">
          {Array.from({length: 4}).map(() => (
            <svg width="22" height="22" fill="#00B67A" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568L24 9.748l-6 5.847 1.416 8.252L12 19.771l-7.416 4.076L6 15.595 0 9.748l8.332-1.593z"/></svg>
          ))}
          <svg width="22" height="22" fill="#00B67A" opacity="0.7" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568L24 9.748l-6 5.847 1.416 8.252L12 19.771l-7.416 4.076L6 15.595 0 9.748l8.332-1.593z"/></svg>
        </div>
        <p class="trustpilot-count">
          Basé sur <strong>1 234 avis</strong> vérifiés
        </p>
        <a href="https://www.trustpilot.com" target="_blank" rel="noopener noreferrer" class="trustpilot-link">
          Voir tous les avis →
        </a>
      </div>

      <div class="trustpilot-reviews">
        {reviews.map((r) => (
          <article class="trustpilot-review">
            <div class="trustpilot-review-header">
              <div class="trustpilot-review-stars">
                {Array.from({length: r.stars}).map(() => (
                  <svg width="14" height="14" fill="#00B67A" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.568L24 9.748l-6 5.847 1.416 8.252L12 19.771l-7.416 4.076L6 15.595 0 9.748l8.332-1.593z"/></svg>
                ))}
              </div>
              <span class="trustpilot-review-date">{r.date}</span>
            </div>
            <p class="trustpilot-review-text">"{r.text}"</p>
            <p class="trustpilot-review-author">— {r.author}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .trustpilot-section {
    background-color: var(--color-brand-white);
  }

  .trustpilot-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .trustpilot-grid {
      grid-template-columns: 1fr 2fr;
      gap: 56px;
    }
  }

  .trustpilot-eyebrow {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-indigo-600, #4033DB);
    margin-bottom: 8px;
  }

  .trustpilot-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 5vw, 68px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .trustpilot-over {
    color: var(--color-graycool-400, #7D89B0);
    font-size: 0.5em;
    font-weight: 600;
  }

  .trustpilot-stars {
    display: flex;
    gap: 4px;
    margin-bottom: 12px;
  }

  .trustpilot-count {
    color: var(--color-graycool-700, #404968);
    font-size: 15px;
    margin-bottom: 4px;
  }

  .trustpilot-link {
    color: var(--color-indigo-600, #4033DB);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }

  .trustpilot-reviews {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  @media (min-width: 768px) {
    .trustpilot-reviews {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .trustpilot-review {
    background-color: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--color-indigo-100, #DEDAFF);
    border-radius: 12px;
    padding: 20px;
  }

  .trustpilot-review-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }

  .trustpilot-review-stars {
    display: flex;
    gap: 2px;
  }

  .trustpilot-review-date {
    font-size: 12px;
    color: var(--color-graycool-500, #5D6B98);
  }

  .trustpilot-review-text {
    color: var(--color-brand-black);
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .trustpilot-review-author {
    font-size: 13px;
    color: var(--color-graycool-700, #404968);
    font-weight: 500;
  }
</style>
