---
const logos = ['BFM Business', 'Capital', 'Les Échos', 'Le Figaro', 'Challenges']
---
<section class="trust-band" aria-label="Logos presse">
  <div class="container-regular">
    <p class="trust-band-label">Ils parlent de nous</p>
    <div class="trust-band-logos">
      {logos.map((logo) => (
        <div class="trust-band-logo">{logo}</div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-band {
    padding: 40px 0;
    background-color: white;
    border-bottom: 1px solid var(--color-indigo-100, #DEDAFF);
  }

  .trust-band-label {
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-graycool-500, #5D6B98);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 20px;
  }

  .trust-band-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .trust-band-logos { gap: 56px; }
  }

  .trust-band-logo {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-graycool-500, #5D6B98);
    letter-spacing: -0.01em;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }

  .trust-band-logo:hover { opacity: 1; }
</style>
