---
interface Props {
  showHeadband?: boolean
  headbandText?: string
}

const {
  showHeadband = true,
  headbandText = "Outil gratuit — LMNP : déclarez vos revenus locatifs et économisez en moyenne 4 800 € d'impôts par an",
} = Astro.props
---

<header class="header-nopillo">
  {showHeadband && (
    <a href="#contact" class="headband">
      <span class="headband-badge">Outil gratuit</span>
      <span class="headband-text">{headbandText}</span>
    </a>
  )}

  <nav class="nav">
    <div class="container-navbar nav-inner">
      <a href="/" class="logo" aria-label="Nopillo accueil">
        <img src="/logo-nopillo.svg" alt="Nopillo" width="140" height="32" />
      </a>

      <ul class="nav-items">
        <li><a href="#problem">Services</a></li>
        <li><a href="#simulator">Outils</a></li>
        <li><a href="#testimonials">Avis</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="#contact">Tarifs</a></li>
      </ul>

      <div class="cta-group">
        <a href="#login" class="btn btn-outline btn-sm">Espace client</a>
        <a href="#contact" class="btn btn-primary btn-sm">Calculer mes économies</a>
      </div>

      <button class="burger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .header-nopillo {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background-color: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
  }

  /* HEADBAND ORANGE (authentique Nopillo) */
  .headband {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 12px;
    background-color: var(--color-orange-100, #FFF3DF);
    color: var(--color-brand-black, #09090B);
    font-size: 14px;
    font-weight: 500;
    padding: 8px 16px;
    text-decoration: none;
    text-align: center;
    transition: background-color 0.15s ease;
  }

  .headband:hover {
    background-color: var(--color-orange-200, #FFE9C9);
  }

  .headband-badge {
    display: inline-block;
    padding: 2px 10px;
    background-color: var(--color-brand-black, #09090B);
    color: white;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }

  .headband-text {
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .headband-text { font-size: 12px; }
  }

  /* NAV */
  .nav {
    height: 72px;
  }

  @media (min-width: 1024px) {
    .nav { height: 80px; }
  }

  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .logo img {
    height: 32px;
    display: block;
  }

  .nav-items {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 32px;
    flex: 1;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .nav-items { display: flex; }
  }

  .nav-items a {
    color: var(--color-brand-black, #09090B);
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-items a:hover {
    color: var(--color-indigo-600, #4033DB);
  }

  .cta-group {
    display: none;
    gap: 8px;
  }

  @media (min-width: 768px) {
    .cta-group { display: flex; }
  }

  .burger {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  @media (min-width: 1024px) {
    .burger { display: none; }
  }

  .burger span {
    width: 22px;
    height: 2px;
    background-color: var(--color-brand-black, #09090B);
    border-radius: 2px;
  }
</style>
