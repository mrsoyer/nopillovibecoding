---
// Card — Composant atomique Nopillo
// Variants : translucent | solid | outlined | feature | testimonial
// Source DS : .claude/skills/apply-nopillo-ds/references/components-anatomy.md

interface Props {
  variant?: 'translucent' | 'solid' | 'outlined' | 'feature' | 'testimonial';
  title?: string;
  icon?: string;       // path SVG ou URL
  href?: string;
  class?: string;
}

const {
  variant = 'solid',
  title,
  icon,
  href,
  class: className = '',
} = Astro.props;

const Tag = href ? 'a' : 'article';
---

<Tag
  href={href}
  class:list={['card', `card-${variant}`, className]}
>
  {icon && (
    <div class="card-icon">
      <img src={icon} alt="" aria-hidden="true" />
    </div>
  )}

  {title && <h3 class="card-title">{title}</h3>}

  <div class="card-body">
    <slot />
  </div>
</Tag>

<style>
  .card {
    display: block;
    padding: 24px;
    border-radius: 16px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    text-decoration: none;
    color: var(--black);
    font-family: var(--font-body);
  }

  a.card:hover {
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  /* Variants */
  .card-translucent {
    background-color: rgba(255, 255, 255, 0.3);
    border: 1px solid var(--indigo-100, #DEDAFF);
    box-shadow: 0 1px 10px rgba(0, 0, 0, 0.06);
  }

  .card-solid {
    background-color: var(--white);
    box-shadow: 0 1px 10px rgba(0, 0, 0, 0.06);
  }

  .card-outlined {
    background-color: var(--white);
    border: 1px solid var(--graycool200, #DCDFEA);
  }

  .card-feature {
    background-color: var(--white);
    border: 1px solid var(--indigo-100, #DEDAFF);
    box-shadow: 0 1px 10px rgba(0, 0, 0, 0.06);
  }

  .card-testimonial {
    background-color: var(--white);
    border: 1px solid var(--indigo-100, #DEDAFF);
    box-shadow: 0 1px 16px rgba(0, 0, 0, 0.08);
  }

  /* Internal */
  .card-icon {
    width: 48px;
    height: 48px;
    background-color: var(--indigo-100, #DEDAFF);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    color: var(--indigo-600);
  }

  .card-icon img {
    width: 24px;
    height: 24px;
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    line-height: 1.1;
    color: var(--black);
    margin: 0 0 12px;
  }

  .card-body {
    font-size: 16px;
    line-height: 1.5;
    color: var(--graycool500, #5D6B98);
  }
</style>
