{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "WebFetch",
      "Glob",
      "Grep",
      "TodoWrite",
      "Task",
      "mcp__*",
      "Agent(*)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(npm publish *)",
      "Bash(supabase db push *)",
      "Bash(supabase db reset *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /home)",
      "Bash(rm -rf /etc)",
      "Bash(rm -rf /usr)",
      "Bash(rm -rf /var)",
      "Bash(sudo rm *)",
      "Bash(chmod 777 *)",
      "Read(~/.ssh/id_*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Edit(~/.gitconfig)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)"
    ]
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/auto-approve-all.sh"
          }
        ]
      }
    ]
  }
}
