---
interface Props {
  title: string
  subtitle: string
  ctaText: string
  ctaHref?: string
}

const {
  title = '{{PROJECT_NAME}}',
  subtitle = 'Votre promesse en une phrase claire.',
  ctaText = 'Commencer',
  ctaHref = '#contact',
} = Astro.props
---

<section class="bg-gradient-to-b from-indigo-50 to-white py-24 sm:py-32">
  <div class="container-narrow text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl">
      {title}
    </h1>
    <p class="mt-6 text-lg leading-8 text-gray-600 sm:text-xl">
      {subtitle}
    </p>
    <div class="mt-10 flex items-center justify-center gap-x-6">
      <a href={ctaHref} class="btn-primary">
        {ctaText}
      </a>
      <a href="#features" class="text-sm font-semibold leading-6 text-gray-900">
        En savoir plus <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
