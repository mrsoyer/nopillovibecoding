  "shadow": {
    "card":     { "$value": { "x": "0", "y": "1px", "blur": "10px", "spread": "0", "color": "rgba(0, 0, 0, 0.06)" }, "$type": "shadow", "$description": "Card default" },
    "elevated": { "$value": { "x": "0", "y": "1px", "blur": "16px", "spread": "0", "color": "rgba(0, 0, 0, 0.08)" }, "$type": "shadow", "$description": "Card hover/focus" },
    "subtle":   { "$value": { "x": "0", "y": "1px", "blur": "10px", "spread": "0", "color": "rgba(0, 0, 0, 0.05)" }, "$type": "shadow" }
  },
  "container": {
    "regular": { "$value": "1120px", "$type": "dimension", "$description": "Container default Nopillo" },
    "navbar":  { "$value": "1408px", "$type": "dimension" }
  },
  "transition": {
    "default": { "$value": "all 0.3s ease", "$type": "transition" },
    "fast":    { "$value": "all 0.15s ease", "$type": "transition" }
  }
